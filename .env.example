# Firebase configuration (browser-safe values should be set in Vite env vars)
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_AUTH_DOMAIN"
VITE_FIREBASE_DATABASE_ID="MY_FIREBASE_DATABASE_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_MEASUREMENT_ID="MY_FIREBASE_MEASUREMENT_ID"

# Generic LLM configuration
LLM_PROVIDER="gemini"
LLM_API_KEY="MY_LLM_API_KEY"
LLM_MODEL="gemini-3.5-flash"

# Provider-specific keys (optional)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY="MY_OPENAI_API_KEY"
DEEPSEAK_API_KEY="MY_DEEPSEAK_API_KEY"
CLAUDE_API_KEY="MY_CLAUDE_API_KEY"

APP_URL="MY_APP_URL"
