{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "User scheduled daily tasks, optionally end-to-end encrypted on details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "notes": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "routine": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "completed", "date", "createdAt", "updatedAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "User activity tracker monitor records used for productivity logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "activityName": { "type": "string" },
        "type": { "type": "string", "enum": ["focus", "rest", "distraction"] },
        "durationMinutes": { "type": "number" },
        "timestamp": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["id", "userId", "activityName", "type", "durationMinutes", "timestamp", "date"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User preferences, goals, free-time, and encryption configs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "futureGoals": { "type": "string" },
        "freeTimeRanges": { "type": "array" },
        "e2eEnabled": { "type": "boolean" },
        "emailReportEnabled": { "type": "boolean" },
        "emailRecipient": { "type": "string" },
        "theme": { "type": "string", "enum": ["dark", "light"] }
      },
      "required": ["userId", "futureGoals", "e2eEnabled", "emailReportEnabled", "emailRecipient"]
    },
    "DailySummary": {
      "title": "DailySummary",
      "description": "Daily metrics summaries including personalized motivation content generated by Gemini.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "tasksCompleted": { "type": "number" },
        "totalTasks": { "type": "number" },
        "focusMinutes": { "type": "number" },
        "restMinutes": { "type": "number" },
        "distractionMinutes": { "type": "number" },
        "moodQuote": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["id", "userId", "tasksCompleted", "totalTasks", "focusMinutes", "restMinutes", "distractionMinutes", "date"]
    },
    "MonthlyEvaluation": {
      "title": "MonthlyEvaluation",
      "description": "Monthly productivity in-depth evaluation and tips created by AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "monthString": { "type": "string" },
        "productivityScore": { "type": "number" },
        "strengths": { "type": "array" },
        "weaknesses": { "type": "array" },
        "recommendations": { "type": "array" }
      },
      "required": ["id", "userId", "monthString", "productivityScore", "strengths", "weaknesses", "recommendations"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Users individual tasks."
    },
    "/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "Monitored productivity duration details."
    },
    "/userSettings/{userId}": {
      "schema": "UserSettings",
      "description": "User explicit configurations."
    },
    "/dailySummaries/{summaryId}": {
      "schema": "DailySummary",
      "description": "Daily achievements and motivation tracking."
    },
    "/monthlyEvaluations/{evalId}": {
      "schema": "MonthlyEvaluation",
      "description": "Monthly performance reviews."
    }
  }
}
